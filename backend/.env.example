# Copy to .env and fill in values. Never commit .env.

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=fitflow

JWT_SECRET_KEY=change_me_to_a_long_random_string

# Optional: public image URLs (Cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Outfit preview: background removal (https://www.remove.bg/api)
# REMOVEBG_API_KEY=

# Optional: dump color debug images from detection
# COLOR_DEBUG=0
